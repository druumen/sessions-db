{
  "name": "@druumen/sessions-db",
  "version": "0.0.1-dev",
  "description": "Cross-session traceability for Claude Code — events.jsonl SSoT + JSON projection cache + 3-priority identity reconciliation",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./lib/index.mjs",
  "types": "./types/index.d.ts",
  "bin": {
    "sessions-db": "./cli/sessions-db.mjs",
    "sessions-db-session-start": "./cli/sessions-db-session-start.mjs"
  },
  "exports": {
    ".": "./lib/index.mjs",
    "./cli": "./cli/sessions-db.mjs",
    "./hook": "./cli/sessions-db-session-start.mjs"
  },
  "files": [
    "lib/",
    "cli/",
    "types/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.tinfant.org:8922/druumen/cn/drummen.git"
  },
  "homepage": "https://druumen.com",
  "keywords": [
    "claude-code",
    "session-tracking",
    "cli",
    "developer-tools"
  ],
  "scripts": {
    "test": "node --test '__tests__/**/*.test.mjs'",
    "build:types": "cd ../.. && tsc -p tsconfig.sessions-db.json",
    "check:types-smoke": "cd ../.. && tsc --noEmit -p packages/sessions-db/__tests__/types-smoke/tsconfig.json",
    "prepublishOnly": "npm run build:types"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
